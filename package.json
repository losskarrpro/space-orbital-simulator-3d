{
  "name": "space-orbital-simulator-3d-fixed",
  "version": "1.0.0",
  "description": "Simulateur orbital 3D interactif complet et fonctionnel (Three.js + physique N-body réaliste). Orbites Terre/Lune/Mars interactives, gravité Kepler, textures HDR, shaders atmosphère, contrôles WASD+souris, UI sliders, export CSV.",
  "main": "index.html",
  "scripts": {
    "dev": "vite --port 7500",
    "build": "vite build",
    "preview": "vite preview --port 7501",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src/**/*.js test/**/*.js"
  },
  "keywords": [
    "three.js",
    "3d",
    "orbital",
    "simulation",
    "n-body",
    "physics",
    "space",
    "astronomy"
  ],
  "author": "Space Orbital Simulator Team",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-jsdoc": "^50.2.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^24.1.1",
    "vite": "^5.4.8"
  },
  "dependencies": {
    "@types/three": "^0.169.0",
    "three": "^0.169.0"
  },
  "peerDependencies": {
    "dat.gui": "^0.7.9"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "volta": {
    "node": "20.17.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
